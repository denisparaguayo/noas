---
// src/components/Header.astro
import { siteInfo } from '../data/siteInfo';
import { getLangFromUrl, useTranslations, useTranslatedPath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const pathname = Astro.url.pathname;
const cleanPathname = pathname.replace(/\/$/, ""); // Remove trailing slash

// Get path without language prefix for active states check
const pathWithoutLang = lang === 'es' ? cleanPathname.replace(/^\/es/, "") : cleanPathname;
const currentRoute = pathWithoutLang === "" ? "/" : pathWithoutLang;

const isHomeActive = currentRoute === "/" || currentRoute === "/index.html";
const isAboutActive = currentRoute === "/about" || currentRoute === "/about.html";
const isContactActive = currentRoute === "/contact" || currentRoute === "/contact.html";

const serviceRoutes = ["/hcleaning", "/moveinout", "/officecleaning", "/janitorial", "/postconstruction"];
const isServicesActive = serviceRoutes.some(route => currentRoute === route || currentRoute === `${route}.html`);

// Calculate links for the language switcher
const alternateLang = lang === 'en' ? 'es' : 'en';
const alternatePathname = translatePath(currentRoute, alternateLang);
---

<header class="sticky top-0 z-50 backdrop-blur-md bg-white/90 border-b border-stone-200/50 shadow-sm transition-all duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-20">
      <!-- Logo -->
      <div class="flex-shrink-0 flex items-center">
        <a href={translatePath('/')} class="flex items-center transition hover:opacity-90">
          <img src="/images/logo.png" alt={`${siteInfo.name} Logo`} class="h-14 w-auto object-contain" />
        </a>
      </div>

      <!-- Desktop Navigation -->
      <nav class="hidden md:flex space-x-8 items-center">
        <a 
          href={translatePath('/')} 
          class={`font-medium transition duration-200 ${isHomeActive ? 'text-amber-600 font-semibold' : 'text-stone-600 hover:text-amber-600'}`}
        >
          {t('nav.home')}
        </a>
        
        <!-- Desktop Services Dropdown -->
        <div class="relative group py-2">
          <button 
            type="button" 
            class={`flex items-center font-medium transition duration-200 focus:outline-none ${isServicesActive ? 'text-amber-600 font-semibold' : 'text-stone-600 hover:text-amber-600'}`}
          >
            <span>{t('nav.services')}</span>
            <svg class="ml-1.5 h-4 w-4 transition-transform duration-200 group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          
          <!-- Dropdown menu -->
          <div class="absolute left-1/2 -translate-x-1/2 mt-2 w-64 rounded-2xl bg-white border border-stone-100 shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible group-hover:translate-y-0 translate-y-2 transition-all duration-200 ease-out z-50 py-2">
            <a href={translatePath('/hcleaning')} class="group/item block px-5 py-3 text-sm text-stone-700 hover:bg-amber-50/50 hover:text-amber-700 transition duration-150">
              <p class="font-semibold">{t('service.hcleaning.title')}</p>
              <p class="text-xs text-stone-500 group-hover/item:text-amber-700/80 mt-0.5 transition-colors duration-150">{t('service.hcleaning.desc')}</p>
            </a>
            <a href={translatePath('/moveinout')} class="group/item block px-5 py-3 text-sm text-stone-700 hover:bg-amber-50/50 hover:text-amber-700 transition duration-150">
              <p class="font-semibold">{t('service.moveinout.title')}</p>
              <p class="text-xs text-stone-500 group-hover/item:text-amber-700/80 mt-0.5 transition-colors duration-150">{t('service.moveinout.desc')}</p>
            </a>
            <a href={translatePath('/officecleaning')} class="group/item block px-5 py-3 text-sm text-stone-700 hover:bg-amber-50/50 hover:text-amber-700 transition duration-150">
              <p class="font-semibold">{t('service.officecleaning.title')}</p>
              <p class="text-xs text-stone-500 group-hover/item:text-amber-700/80 mt-0.5 transition-colors duration-150">{t('service.officecleaning.desc')}</p>
            </a>
            <a href={translatePath('/janitorial')} class="group/item block px-5 py-3 text-sm text-stone-700 hover:bg-amber-50/50 hover:text-amber-700 transition duration-150">
              <p class="font-semibold">{t('service.janitorial.title')}</p>
              <p class="text-xs text-stone-500 group-hover/item:text-amber-700/80 mt-0.5 transition-colors duration-150">{t('service.janitorial.desc')}</p>
            </a>
            <a href={translatePath('/postconstruction')} class="group/item block px-5 py-3 text-sm text-stone-700 hover:bg-amber-50/50 hover:text-amber-700 transition duration-150">
              <p class="font-semibold">{t('service.postconstruction.title')}</p>
              <p class="text-xs text-stone-500 group-hover/item:text-amber-700/80 mt-0.5 transition-colors duration-150">{t('service.postconstruction.desc')}</p>
            </a>
            <div class="border-t border-stone-50 mt-1 pt-1">
              <a href={translatePath('/#services')} class="block px-5 py-2.5 text-xs font-bold text-center text-amber-600 hover:bg-amber-50 transition duration-150" set:html={t('service.all')}>
              </a>
            </div>
          </div>
        </div>

        <a 
          href={translatePath('/about')} 
          class={`font-medium transition duration-200 ${isAboutActive ? 'text-amber-600 font-semibold' : 'text-stone-600 hover:text-amber-600'}`}
        >
          {t('nav.about')}
        </a>
        <a 
          href={translatePath('/contact')} 
          class={`font-medium transition duration-200 ${isContactActive ? 'text-amber-600 font-semibold' : 'text-stone-600 hover:text-amber-600'}`}
        >
          {t('nav.contact')}
        </a>
        <a href={translatePath('/contact')} class="inline-flex items-center justify-center px-5 py-2.5 border border-transparent text-sm font-semibold rounded-xl text-stone-950 bg-amber-500 hover:bg-amber-400 shadow-sm transition duration-200">
          {t('btn.quote')}
        </a>

        <!-- Language Switcher Desktop -->
        <div class="flex items-center space-x-1 border-l border-stone-250/60 pl-4 ml-1">
          <a 
            href={lang === 'en' ? '#' : alternatePathname} 
            class={`text-[11px] font-bold px-2.5 py-1.5 rounded-xl transition duration-200 ${lang === 'en' ? 'bg-amber-500 text-stone-950 shadow-sm pointer-events-none' : 'text-stone-500 hover:text-stone-850 hover:bg-stone-100'}`}
          >
            EN
          </a>
          <a 
            href={lang === 'es' ? '#' : alternatePathname} 
            class={`text-[11px] font-bold px-2.5 py-1.5 rounded-xl transition duration-200 ${lang === 'es' ? 'bg-amber-500 text-stone-950 shadow-sm pointer-events-none' : 'text-stone-500 hover:text-stone-850 hover:bg-stone-100'}`}
          >
            ES
          </a>
        </div>
      </nav>

      <!-- Mobile menu button -->
      <div class="md:hidden flex items-center">
        <button id="menu-toggle" type="button" class="inline-flex items-center justify-center p-2 rounded-xl text-stone-500 hover:text-amber-600 hover:bg-stone-100 focus:outline-none transition duration-200" aria-controls="mobile-menu" aria-expanded="false">
          <span class="sr-only">Open main menu</span>
          <svg class="h-6 w-6 block" id="menu-icon-hamburger" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
          </svg>
          <svg class="h-6 w-6 hidden" id="menu-icon-close" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu, show/hide based on menu state. -->
  <div class="hidden md:hidden animate-fade-in" id="mobile-menu">
    <div class="px-3 pt-2 pb-4 space-y-1 bg-white border-b border-stone-200/50 shadow-lg">
      <a href={translatePath('/')} class="mobile-nav-link block px-4 py-3 rounded-xl text-base font-semibold text-stone-700 hover:text-amber-600 hover:bg-stone-50 transition">{t('nav.home')}</a>
      
      <!-- Mobile Collapsible Services -->
      <div>
        <button id="mobile-services-toggle" type="button" class="w-full flex justify-between items-center px-4 py-3 rounded-xl text-base font-semibold text-stone-700 hover:text-amber-600 hover:bg-stone-50 transition focus:outline-none">
          <span>{t('nav.services')}</span>
          <svg id="mobile-services-arrow" class="h-4 w-4 transition-transform duration-200 text-stone-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div id="mobile-services-menu" class="hidden pl-4 pr-2 py-2 space-y-1 bg-stone-50/50 rounded-xl mt-1">
          <a href={translatePath('/hcleaning')} class="mobile-nav-link block px-4 py-2.5 rounded-lg text-sm font-medium text-stone-600 hover:text-amber-600 hover:bg-stone-100 transition">{t('service.hcleaning.title')}</a>
          <a href={translatePath('/moveinout')} class="mobile-nav-link block px-4 py-2.5 rounded-lg text-sm font-medium text-stone-600 hover:text-amber-600 hover:bg-stone-100 transition">{t('service.moveinout.title')}</a>
          <a href={translatePath('/officecleaning')} class="mobile-nav-link block px-4 py-2.5 rounded-lg text-sm font-medium text-stone-600 hover:text-amber-600 hover:bg-stone-100 transition">{t('service.officecleaning.title')}</a>
          <a href={translatePath('/janitorial')} class="mobile-nav-link block px-4 py-2.5 rounded-lg text-sm font-medium text-stone-600 hover:text-amber-600 hover:bg-stone-100 transition">{t('service.janitorial.title')}</a>
          <a href={translatePath('/postconstruction')} class="mobile-nav-link block px-4 py-2.5 rounded-lg text-sm font-medium text-stone-600 hover:text-amber-600 hover:bg-stone-100 transition">{t('service.postconstruction.title')}</a>
          <a href={translatePath('/#services')} class="mobile-nav-link block px-4 py-2.5 rounded-lg text-sm font-bold text-amber-600 hover:bg-stone-100 transition" set:html={t('service.all')}></a>
        </div>
      </div>

      <a href={translatePath('/about')} class="mobile-nav-link block px-4 py-3 rounded-xl text-base font-semibold text-stone-700 hover:text-amber-600 hover:bg-stone-50 transition">{t('nav.about')}</a>
      <a href={translatePath('/contact')} class="mobile-nav-link block px-4 py-3 rounded-xl text-base font-semibold text-stone-700 hover:text-amber-600 hover:bg-stone-50 transition">{t('nav.contact')}</a>
      <div class="pt-4 pb-2 px-4 border-t border-stone-100 mt-2">
        <a href={translatePath('/contact')} class="w-full inline-flex items-center justify-center px-5 py-3 border border-transparent text-base font-bold rounded-xl text-stone-950 bg-amber-500 hover:bg-amber-600 shadow transition">
          {t('btn.quote')}
        </a>
      </div>

      <!-- Mobile Language Switcher -->
      <div class="flex items-center justify-between px-4 py-3 border-t border-stone-100 mt-2">
        <span class="text-sm font-semibold text-stone-500">Language / Idioma</span>
        <div class="flex items-center space-x-2">
          <a 
            href={lang === 'en' ? '#' : alternatePathname} 
            class={`text-xs font-bold px-3 py-1.5 rounded-xl transition ${lang === 'en' ? 'bg-amber-500 text-stone-950 pointer-events-none' : 'text-stone-600 bg-stone-50 hover:bg-stone-100'}`}
          >
            English
          </a>
          <a 
            href={lang === 'es' ? '#' : alternatePathname} 
            class={`text-xs font-bold px-3 py-1.5 rounded-xl transition ${lang === 'es' ? 'bg-amber-500 text-stone-950 pointer-events-none' : 'text-stone-600 bg-stone-50 hover:bg-stone-100'}`}
          >
            Español
          </a>
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const menuToggle = document.getElementById('menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    const hamburgerIcon = document.getElementById('menu-icon-hamburger');
    const closeIcon = document.getElementById('menu-icon-close');
    const navLinks = document.querySelectorAll('.mobile-nav-link');

    if (menuToggle && mobileMenu && hamburgerIcon && closeIcon) {
      menuToggle.addEventListener('click', () => {
        const isExpanded = menuToggle.getAttribute('aria-expanded') === 'true';
        
        // Toggle visibility
        mobileMenu.classList.toggle('hidden');
        hamburgerIcon.classList.toggle('hidden');
        closeIcon.classList.toggle('hidden');
        
        menuToggle.setAttribute('aria-expanded', !isExpanded ? 'true' : 'false');
      });

      // Close menu on link click, except when clicking the services toggle itself
      navLinks.forEach(link => {
        if (link.id !== 'mobile-services-toggle' && !link.closest('#mobile-services-toggle')) {
          link.addEventListener('click', () => {
            mobileMenu.classList.add('hidden');
            hamburgerIcon.classList.remove('hidden');
            closeIcon.classList.add('hidden');
            menuToggle.setAttribute('aria-expanded', 'false');
          });
        }
      });
    }

    // Add mobile services toggle functionality
    const mobileServicesToggle = document.getElementById('mobile-services-toggle');
    const mobileServicesMenu = document.getElementById('mobile-services-menu');
    const mobileServicesArrow = document.getElementById('mobile-services-arrow');

    if (mobileServicesToggle && mobileServicesMenu && mobileServicesArrow) {
      mobileServicesToggle.addEventListener('click', (e) => {
        e.stopPropagation();
        const isHidden = mobileServicesMenu.classList.contains('hidden');
        if (isHidden) {
          mobileServicesMenu.classList.remove('hidden');
          mobileServicesArrow.classList.add('rotate-180');
        } else {
          mobileServicesMenu.classList.add('hidden');
          mobileServicesArrow.classList.remove('rotate-180');
        }
      });
    }
  });
</script>
