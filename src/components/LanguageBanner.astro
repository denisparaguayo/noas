---
// src/components/LanguageBanner.astro
interface Props {
  spanishPath: string;
}

const { spanishPath } = Astro.props;
---

<div 
  id="lang-banner" 
  class="fixed bottom-4 left-4 right-4 sm:left-auto sm:bottom-6 sm:right-6 z-50 max-w-[calc(100vw-2rem)] sm:max-w-sm bg-white/95 backdrop-blur-md border border-stone-200/80 rounded-2xl shadow-xl p-4 transition-all duration-500 ease-in-out transform translate-y-20 opacity-0 pointer-events-none"
  data-path={spanishPath}
>
  <div class="flex items-start gap-3">
    <div class="text-2xl mt-0.5 flex-shrink-0">🌐</div>
    <div class="flex-grow">
      <h4 class="font-bold text-stone-900 text-sm">¿Prefieres español?</h4>
      <p class="text-stone-600 text-xs mt-1">Hemos detectado que tu navegador está en español.</p>
      <div class="flex items-center gap-3 mt-3">
        <a 
          href={spanishPath}
          class="bg-amber-500 hover:bg-amber-600 text-stone-950 text-xs font-bold px-3.5 py-1.5 rounded-lg shadow-sm transition"
        >
          Ver en Español
        </a>
        <button 
          id="close-lang-banner"
          class="text-stone-500 hover:text-stone-800 text-xs font-semibold px-2 py-1.5 transition"
        >
          No, gracias
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  const banner = document.getElementById('lang-banner');
  const closeBtn = document.getElementById('close-lang-banner');

  if (banner && closeBtn) {
    // Check if the user has already dismissed the banner in this session
    const hasDismissed = sessionStorage.getItem('dismissed-lang-banner');
    
    if (!hasDismissed) {
      // Check browser language
      const browserLang = navigator.language || (navigator as any).userLanguage;
      
      if (browserLang && browserLang.startsWith('es')) {
        // Show banner with a smooth slide-in animation after a delay
        setTimeout(() => {
          banner.classList.remove('translate-y-20', 'opacity-0', 'pointer-events-none');
          banner.classList.add('translate-y-0', 'opacity-100');
        }, 1500);
      }
    }

    closeBtn.addEventListener('click', () => {
      // Hide banner
      banner.classList.remove('translate-y-0', 'opacity-100');
      banner.classList.add('translate-y-20', 'opacity-0', 'pointer-events-none');
      // Store session key so it doesn't appear again on other pages during this session
      sessionStorage.setItem('dismissed-lang-banner', 'true');
    });
  }
</script>
