---
// src/components/AboutHome.astro
import { siteInfo } from '../data/siteInfo';
import { getLangFromUrl, useTranslations, useTranslatedPath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
---

<section id="about" class="py-24 bg-white relative overflow-hidden">
  <!-- Subtle background glow -->
  <div class="absolute -right-32 top-1/4 w-80 h-80 bg-amber-500/5 rounded-full blur-3xl"></div>
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <div class="relative">
        <img src="/images/noa.png" alt="Nohemi Alvarado - Founder" class="rounded-3xl shadow-xl w-full h-[450px] object-cover border border-stone-100" />
        <div class="absolute -bottom-6 -right-6 w-32 h-32 bg-amber-500/10 rounded-full blur-xl -z-10"></div>
        <div class="absolute -top-6 -left-6 w-32 h-32 bg-orange-500/10 rounded-full blur-xl -z-10"></div>
      </div>
      <div class="space-y-6">
        <span class="text-xs font-bold text-amber-600 uppercase tracking-wider bg-amber-50 px-3 py-1 rounded-full border border-amber-100">
          {lang === 'es' ? 'Sobre Nuestra Empresa' : 'About Our Company'}
        </span>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-stone-900 mt-2">
          {lang === 'es' ? 'Dedicados a la Excelencia Desde el Primer Día' : 'Dedicated to Excellence Since Day One'}
        </h2>
        <p class="text-stone-600 leading-relaxed text-lg">
          {lang === 'es' ? (
            `En ${siteInfo.legalName}, estamos comprometidos a brindar soluciones de limpieza de primer nivel que transforman los espacios en ambientes impecables, acogedores y saludables.`
          ) : (
            `At ${siteInfo.legalName}, we are committed to providing top-tier cleaning solutions that transform spaces into spotless, welcoming, and healthy environments.`
          )}
        </p>
        <p class="text-stone-600 leading-relaxed">
          {lang === 'es' ? (
            `Fundada por ${siteInfo.founder}, una inmigrante de Paraguay con una sólida ética de trabajo y profunda experiencia en la industria, nuestra empresa ha construido una sólida reputación en el ${t('site.serviceArea')}. Nos enorgullecemos de nuestra atención al detalle, prácticas ecológicas y confiabilidad.`
          ) : (
            `Founded by ${siteInfo.founder}, an immigrant from Paraguay with a strong work ethic and deep experience in the industry, our company has built a solid reputation in the ${t('site.serviceArea')}. We pride ourselves on attention to detail, eco-friendly practices, and reliability.`
          )}
        </p>
        <div class="pt-4">
          <a href={translatePath('/about')} class="inline-flex items-center justify-center px-6 py-3 border-2 border-amber-500 text-base font-semibold rounded-xl text-amber-700 hover:bg-amber-50 hover:text-amber-800 transition duration-300">
            {lang === 'es' ? 'Conozca Nuestra Historia' : 'Read Our Story'}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
