---
// src/components/BusinessHours.astro
import { siteInfo } from '../data/siteInfo';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="hours" class="py-14 bg-[#faf8f5] border-b border-stone-200/50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="bg-white rounded-3xl p-6 sm:p-10 border border-stone-200/60 shadow-sm flex flex-col lg:flex-row justify-between items-center gap-8 relative overflow-hidden">
      <!-- Decorative background blur -->
      <div class="absolute -right-10 -bottom-10 w-40 h-40 bg-amber-500/5 rounded-full blur-2xl"></div>
      
      <div class="relative z-10 flex items-start gap-4">
        <div class="w-12 h-12 rounded-2xl bg-amber-50 flex items-center justify-center text-amber-600 flex-shrink-0">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <div>
          <h2 class="text-2xl sm:text-3xl font-extrabold text-stone-900 mb-2">{t('site.businessHours.title')}</h2>
          <p class="text-stone-500 text-sm">{t('site.businessHours.subtitle')}</p>
        </div>
      </div>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 w-full lg:w-auto relative z-10">
        <!-- Weekdays Card -->
        <div class="bg-stone-50/60 p-4 rounded-2xl border border-stone-100 shadow-sm flex items-center space-x-4">
          <div class="w-10 h-10 rounded-xl bg-amber-100/70 flex items-center justify-center text-amber-800 font-bold text-sm">
            W
          </div>
          <div>
            <p class="text-[11px] text-stone-500 font-bold uppercase tracking-wider">{t('site.businessHours.weekdays')}</p>
            <p class="text-sm font-extrabold text-stone-850">{siteInfo.businessHours.weekdays.hours}</p>
          </div>
        </div>
        <!-- Saturdays Card -->
        <div class="bg-stone-50/60 p-4 rounded-2xl border border-stone-100 shadow-sm flex items-center space-x-4">
          <div class="w-10 h-10 rounded-xl bg-orange-100/70 flex items-center justify-center text-orange-800 font-bold text-sm">
            S
          </div>
          <div>
            <p class="text-[11px] text-stone-500 font-bold uppercase tracking-wider">{t('site.businessHours.saturdays')}</p>
            <p class="text-sm font-extrabold text-stone-850">{siteInfo.businessHours.saturdays.hours}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
