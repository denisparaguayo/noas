---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import { siteInfo } from '../data/siteInfo';
import Hero from '../components/Hero.astro';
import BusinessHours from '../components/BusinessHours.astro';
import ServicesHome from '../components/ServicesHome.astro';
import AboutHome from '../components/AboutHome.astro';
import ContactForm from '../components/ContactForm.astro';
---

<Layout title={`${siteInfo.legalName} - Professional Cleaning Services in ${siteInfo.serviceArea.display}`}>
  <Hero />
  <BusinessHours />
  <ServicesHome />
  <AboutHome />
  <ContactForm />
</Layout>
