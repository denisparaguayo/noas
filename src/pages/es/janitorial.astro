---
// src/pages/es/janitorial.astro
import Layout from '../../layouts/Layout.astro';
import { siteInfo } from '../../data/siteInfo';
---

<Layout 
  title={`Servicios Profesionales de Conserjería | ${siteInfo.legalName}`} 
  description={`Garantice un entorno limpio e higiénico con nuestros servicios de conserjería en el ${siteInfo.serviceArea.display}. Planes diarios, semanales y mensuales adaptados a sus necesidades.`}
>
  <!-- Header Page Title -->
  <section class="bg-slate-900 text-white py-16 sm:py-24 relative overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/5.jpg" alt="Banner de servicios de conserjería" class="w-full h-full object-cover opacity-25" />
      <div class="absolute inset-0 bg-slate-950/80"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight">Servicios de Conserjería</h1>
      <p class="mt-4 text-lg text-slate-300 max-w-2xl mx-auto">
        Programas de limpieza de rutina y mantenimiento meticuloso para mantener sus instalaciones higiénicas y funcionando sin problemas.
      </p>
    </div>
  </section>

  <!-- Service Detail Content -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        
        <!-- Main Image -->
        <div>
          <img src="/images/5.jpg" alt="Detalles de servicios de conserjería" class="rounded-2xl shadow-xl w-full h-[400px] object-cover" />
          <div class="mt-6 bg-blue-50 p-6 rounded-2xl border border-blue-100/50">
            <h3 class="text-lg font-bold text-blue-900 mb-2">🏢 Gestión de Instalaciones a Medida</h3>
            <p class="text-sm text-blue-800 leading-relaxed">
              Atendemos propiedades comerciales, instalaciones educativas, centros de salud y edificios industriales. Colaboramos con los gerentes de las instalaciones para desarrollar procedimientos operativos de limpieza estándar y personalizados.
            </p>
          </div>
        </div>

        <!-- Details -->
        <div class="space-y-8">
          <div>
            <h2 class="text-3xl font-extrabold text-slate-900 mb-4">Consistencia y Cuidado</h2>
            <p class="text-slate-600 leading-relaxed">
              Una instalación bien mantenida es vital para la salud pública, la seguridad y la eficiencia operativa. Nuestros servicios profesionales de conserjería brindan un mantenimiento continuo diario, semanal o mensual para mantener impecables y debidamente abastecidas las áreas comunes, baños, pasillos y salas de reuniones.
            </p>
          </div>

          <div>
            <h3 class="text-xl font-bold text-slate-900 mb-4">Nuestros Servicios de Conserjería Incluyen:</h3>
            <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-slate-600">
              <li class="flex items-center space-x-3">
                <span class="text-emerald-500 font-bold">✓</span>
                <span>Eliminación diaria de basura y reciclaje</span>
              </li>
              <li class="flex items-center space-x-3">
                <span class="text-emerald-500 font-bold">✓</span>
                <span>Limpieza profunda y desinfección de baños</span>
              </li>
              <li class="flex items-center space-x-3">
                <span class="text-emerald-500 font-bold">✓</span>
                <span>Barrido, trapeado y cuidado de pisos</span>
              </li>
              <li class="flex items-center space-x-3">
                <span class="text-emerald-500 font-bold">✓</span>
                <span>Limpieza de superficies en áreas comunes</span>
              </li>
              <li class="flex items-center space-x-3">
                <span class="text-emerald-500 font-bold">✓</span>
                <span>Limpieza de vidrios y espejos</span>
              </li>
              <li class="flex items-center space-x-3">
                <span class="text-emerald-500 font-bold">✓</span>
                <span>Desinfección de cocinas y salas de descanso</span>
              </li>
              <li class="flex items-center space-x-3">
                <span class="text-emerald-500 font-bold">✓</span>
                <span>Sacudir conductos, persianas y superficies altas</span>
              </li>
              <li class="flex items-center space-x-3">
                <span class="text-emerald-500 font-bold">✓</span>
                <span>Reposición de jabón y productos de papel</span>
              </li>
            </ul>
          </div>

          <!-- CTAs -->
          <div class="pt-6 flex flex-col sm:flex-row gap-4 border-t border-slate-100">
            <a 
              href={`https://wa.me/${siteInfo.phone.raw}?text=Hola!%20Estoy%20interesado%20en%20sus%20servicios%20de%20conserjeria.`} 
              target="_blank" 
              rel="noopener noreferrer" 
              class="inline-flex items-center justify-center px-6 py-3.5 border border-transparent text-base font-semibold rounded-xl text-white bg-green-600 hover:bg-green-700 shadow transition duration-200"
            >
              Reservar por WhatsApp
            </a>
            <a 
              href="/es/#services" 
              class="inline-flex items-center justify-center px-6 py-3.5 border border-slate-200 text-base font-semibold rounded-xl text-slate-600 hover:bg-slate-50 transition duration-200"
            >
              Volver a Servicios
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>
</Layout>
