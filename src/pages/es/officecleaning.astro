---
// src/pages/es/officecleaning.astro
import Layout from '../../layouts/Layout.astro';
import { siteInfo } from '../../data/siteInfo';
---

<Layout 
  title={`Servicios Profesionales de Limpieza de Oficinas | ${siteInfo.legalName}`} 
  description={`Mantenga un espacio de trabajo limpio y saludable con nuestros servicios de limpieza de oficinas en el ${siteInfo.serviceArea.display}. Equipo de limpieza puntual, confiable y profesional.`}
>
  <!-- Header Page Title -->
  <section class="bg-slate-900 text-white py-16 sm:py-24 relative overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/4.jpg" alt="Banner de limpieza de oficinas" class="w-full h-full object-cover opacity-25" />
      <div class="absolute inset-0 bg-slate-950/80"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight font-sans">Limpieza de Oficinas</h1>
      <p class="mt-4 text-lg text-slate-300 max-w-2xl mx-auto">
        Mantenga su entorno empresarial limpio, desinfectado y profesional para su equipo y sus clientes.
      </p>
    </div>
  </section>

  <!-- Service Detail Content -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        
        <!-- Main Image -->
        <div>
          <img src="/images/4.jpg" alt="Detalles de limpieza de oficinas" class="rounded-2xl shadow-xl w-full h-[400px] object-cover" />
          <div class="mt-6 bg-blue-50 p-6 rounded-2xl border border-blue-100/50">
            <h3 class="text-lg font-bold text-blue-900 mb-2">💼 Horarios Corporativos a Medida</h3>
            <p class="text-sm text-blue-800 leading-relaxed">
              Ofrecemos planes de limpieza diarios, semanales o quincenales fuera del horario comercial normal para evitar cualquier interrupción en su jornada laboral. Póngase en contacto para personalizar un plan que se adapte a sus necesidades corporativas.
            </p>
          </div>
        </div>

        <!-- Details -->
        <div class="space-y-8">
          <div>
            <h2 class="text-3xl font-extrabold text-slate-900 mb-4">Un Espacio de Trabajo Productivo</h2>
            <p class="text-slate-600 leading-relaxed">
              Un espacio de trabajo limpio es clave para la productividad, la seguridad de los empleados y una experiencia positiva para el cliente. Nuestro dedicado equipo de limpieza comercial mantiene oficinas, tiendas minoristas y sedes corporativas impecables, asegurando que las superficies de alto contacto estén completamente desinfectadas.
            </p>
          </div>

          <div>
            <h3 class="text-xl font-bold text-slate-900 mb-4">Nuestra Limpieza de Oficina Incluye:</h3>
            <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-slate-600">
              <li class="flex items-center space-x-3">
                <span class="text-emerald-500 font-bold">✓</span>
                <span>Sacudir y limpiar escritorios y equipos electrónicos</span>
              </li>
              <li class="flex items-center space-x-3">
                <span class="text-emerald-500 font-bold">✓</span>
                <span>Aspirar alfombras y trapear pisos</span>
              </li>
              <li class="flex items-center space-x-3">
                <span class="text-emerald-500 font-bold">✓</span>
                <span>Desinfectar baños y cocinas</span>
              </li>
              <li class="flex items-center space-x-3">
                <span class="text-emerald-500 font-bold">✓</span>
                <span>Vaciar contenedores de basura y reciclaje</span>
              </li>
              <li class="flex items-center space-x-3">
                <span class="text-emerald-500 font-bold">✓</span>
                <span>Desinfectar áreas de alto contacto</span>
              </li>
              <li class="flex items-center space-x-3">
                <span class="text-emerald-500 font-bold">✓</span>
                <span>Limpieza de vidrios y ventanas interiores</span>
              </li>
              <li class="flex items-center space-x-3">
                <span class="text-emerald-500 font-bold">✓</span>
                <span>Limpieza de salas de descanso y reuniones</span>
              </li>
              <li class="flex items-center space-x-3">
                <span class="text-emerald-500 font-bold">✓</span>
                <span>Reposición de suministros de higiene</span>
              </li>
            </ul>
          </div>

          <!-- CTAs -->
          <div class="pt-6 flex flex-col sm:flex-row gap-4 border-t border-slate-100">
            <a 
              href={`https://wa.me/${siteInfo.phone.raw}?text=Hola!%20Estoy%20interesado%20en%20sus%20servicios%20de%20limpieza%20de%20oficinas.`} 
              target="_blank" 
              rel="noopener noreferrer" 
              class="inline-flex items-center justify-center px-6 py-3.5 border border-transparent text-base font-semibold rounded-xl text-white bg-green-600 hover:bg-green-700 shadow transition duration-200"
            >
              Reservar por WhatsApp
            </a>
            <a 
              href="/es/#services" 
              class="inline-flex items-center justify-center px-6 py-3.5 border border-slate-200 text-base font-semibold rounded-xl text-slate-600 hover:bg-slate-50 transition duration-200"
            >
              Volver a Servicios
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>
</Layout>
