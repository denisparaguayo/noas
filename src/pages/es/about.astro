---
// src/pages/es/about.astro
import Layout from '../../layouts/Layout.astro';
import { siteInfo } from '../../data/siteInfo';
---

<Layout 
  title={`Sobre Nosotros | ${siteInfo.legalName}`} 
  description={`Conozca más sobre ${siteInfo.legalName}. Empresa fundada por ${siteInfo.founder}, brindando servicios de limpieza confiables y de alta calidad en el ${siteInfo.serviceArea.display} por más de ${siteInfo.yearsOfExperience} años.`}
>
  <!-- Header Page Title -->
  <section class="bg-slate-900 text-white py-16 sm:py-24 relative overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/bg_2.jpg" alt="Fondo de servicio de limpieza" class="w-full h-full object-cover opacity-25" />
      <div class="absolute inset-0 bg-slate-950/80"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight">Sobre Nuestra Empresa</h1>
      <p class="mt-4 text-lg text-slate-300 max-w-2xl mx-auto">
        Descubra nuestra historia, valores y el compromiso de hacer brillar sus espacios.
      </p>
    </div>
  </section>

  <!-- Company Intro and Story -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <span class="text-sm font-bold text-blue-600 uppercase tracking-wider">Nuestra Historia</span>
          <h2 class="text-3xl sm:text-4xl font-extrabold text-slate-900 mt-2 mb-6">De Paraguay al {siteInfo.serviceArea.display}</h2>
          <div class="space-y-6 text-slate-600 leading-relaxed text-base">
            <p>
              Nuestra fundadora, <strong>{siteInfo.founder}</strong>, emigró a los Estados Unidos desde Paraguay hace más de {siteInfo.yearsOfExperience} años. Con una profunda pasión por el orden y la limpieza combinada con una fuerte ética de trabajo, rápidamente se dio cuenta de la necesidad de servicios de limpieza confiables, de alta calidad y asequibles en la comunidad local.
            </p>
            <p>
              Lo que comenzó como un emprendimiento de limpieza de una sola mujer ha crecido hasta convertirse en <strong>{siteInfo.legalName}</strong>, una empresa de limpieza de total confianza y altamente recomendada que atiende a hogares, negocios y sitios de construcción en todo {siteInfo.serviceArea.regions.slice(0, -1).join(', ')} y {siteInfo.serviceArea.regions.slice(-1)}.
            </p>
            <p>
              Hoy en día, contamos con un equipo dedicado de profesionales de la limpieza experimentados y con antecedentes verificados que tratan cada espacio en el que entran con el mayor respeto y cuidado. Utilizamos técnicas de limpieza ecológicas y productos seguros para proteger tanto el medio ambiente como la salud de su familia.
            </p>
          </div>
        </div>
        <div class="relative">
          <img src="/images/noa.png" alt="Equipo de Noa Cleaning Service" class="rounded-2xl shadow-2xl w-full h-[450px] object-cover" />
          <div class="absolute -bottom-6 -left-6 w-24 h-24 bg-blue-500/10 rounded-full blur-xl -z-10"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Core Values Grid -->
  <section class="py-20 bg-slate-50 border-t border-slate-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <span class="text-sm font-bold text-blue-600 uppercase tracking-wider">Nuestros Pilares</span>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-slate-900 mt-2">Misión, Visión y Valores</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Mission -->
        <div class="bg-white p-8 rounded-2xl border border-slate-100 shadow-sm hover:shadow-md transition">
          <div class="w-12 h-12 rounded-xl bg-blue-50 flex items-center justify-center text-blue-600 text-2xl font-bold mb-6">🎯</div>
          <h3 class="text-xl font-bold text-slate-900 mb-3">Nuestra Misión</h3>
          <p class="text-slate-600 text-sm leading-relaxed">
            Ofrecer servicios de limpieza excepcionales que superen las expectativas, transformando las propiedades en entornos saludables, impecables y acogedores para familias y empresas.
          </p>
        </div>

        <!-- Values -->
        <div class="bg-white p-8 rounded-2xl border border-slate-100 shadow-sm hover:shadow-md transition">
          <div class="w-12 h-12 rounded-xl bg-emerald-50 flex items-center justify-center text-emerald-600 text-2xl font-bold mb-6">🤝</div>
          <h3 class="text-xl font-bold text-slate-900 mb-3">Nuestros Valores</h3>
          <p class="text-slate-600 text-sm leading-relaxed">
            La honestidad, la integridad, la puntualidad y el respeto están en el centro de todo lo que hacemos. Creemos en la construcción de relaciones duraderas de confianza con nuestros clientes.
          </p>
        </div>

        <!-- Guarantee -->
        <div class="bg-white p-8 rounded-2xl border border-slate-100 shadow-sm hover:shadow-md transition">
          <div class="w-12 h-12 rounded-xl bg-blue-50 flex items-center justify-center text-blue-600 text-2xl font-bold mb-6">⭐</div>
          <h3 class="text-xl font-bold text-slate-900 mb-3">Garantía de Satisfacción</h3>
          <p class="text-slate-600 text-sm leading-relaxed">
            Su satisfacción es nuestra garantía. Si no está completamente satisfecho con nuestro trabajo, volveremos a su propiedad y limpiaremos el área nuevamente sin costo adicional.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Call to action -->
  <section class="py-16 bg-white border-t border-slate-100">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-extrabold text-slate-900 mb-6">¿Listo para experimentar la diferencia Noa?</h2>
      <p class="text-lg text-slate-600 mb-8 max-w-2xl mx-auto">
        Programe su consulta gratuita hoy o hable con un miembro de nuestro equipo a través de WhatsApp.
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a href="/es/contact" class="inline-flex items-center justify-center px-6 py-3.5 border border-transparent text-base font-semibold rounded-xl text-white bg-blue-600 hover:bg-blue-700 shadow transition duration-200">
          Obtener Cotización Gratis
        </a>
        <a href={`https://wa.me/${siteInfo.phone.raw}?text=Hola!%20Estoy%20interesado%20en%20obtener%2520mas%20informacion%20sobre%20los%20servicios%20de%20Noa%20Cleaning.`} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center px-6 py-3.5 border border-transparent text-base font-semibold rounded-xl text-white bg-green-600 hover:bg-green-700 shadow transition duration-200">
          Chatear por WhatsApp
        </a>
      </div>
    </div>
  </section>

</Layout>
