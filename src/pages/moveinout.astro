---
// src/pages/moveinout.astro
import Layout from '../layouts/Layout.astro';
import { siteInfo } from '../data/siteInfo';
---

<Layout 
  title={`Professional Move In/Move Out Cleaning | ${siteInfo.legalName}`} 
  description={`Prepare your home or secure your deposit return with our move in/move out cleaning services in the ${siteInfo.serviceArea.display}. Deep cleaning for a seamless transition.`}
>
  <!-- Header Page Title -->
  <section class="bg-slate-900 text-white py-16 sm:py-24 relative overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/2.jpg" alt="Move In/Move Out Cleaning Banner" class="w-full h-full object-cover opacity-25" />
      <div class="absolute inset-0 bg-slate-950/80"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight font-sans">Move In/Move Out Cleaning</h1>
      <p class="mt-4 text-lg text-slate-300 max-w-2xl mx-auto">
        Thorough, deep cleaning to make moving in or out of your home completely hassle-free.
      </p>
    </div>
  </section>

  <!-- Service Detail Content -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        
        <!-- Main Image -->
        <div>
          <img src="/images/2.jpg" alt="Move In/Move Out Cleaning Details" class="rounded-2xl shadow-xl w-full h-[400px] object-cover" />
          <div class="mt-6 bg-blue-50 p-6 rounded-2xl border border-blue-100/50">
            <h3 class="text-lg font-bold text-blue-900 mb-2">⭐ Get Your Security Deposit Back</h3>
            <p class="text-sm text-blue-800 leading-relaxed">
              For tenants, moving out can be stressful. Our deep-clean service is designed to satisfy landlords and property managers, helping you secure your security deposit return without any disputes.
            </p>
          </div>
        </div>

        <!-- Details -->
        <div class="space-y-8">
          <div>
            <h2 class="text-3xl font-extrabold text-slate-900 mb-4">A Seamless Transition</h2>
            <p class="text-slate-600 leading-relaxed">
              Moving into a new home or leaving an old one requires tremendous effort. Our move-in/move-out cleaning service ensures that the property is completely sanitized, fresh, and ready for new residents. We clean the deep, hard-to-reach areas that get overlooked during daily maintenance.
            </p>
          </div>

          <div>
            <h3 class="text-xl font-bold text-slate-900 mb-4">Our Move-in / Move-out Services Include:</h3>
            <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-slate-600">
              <li class="flex items-center space-x-3">
                <span class="text-emerald-500 font-bold">✓</span>
                <span>Deep cleaning of kitchens & bathrooms</span>
              </li>
              <li class="flex items-center space-x-3">
                <span class="text-emerald-500 font-bold">✓</span>
                <span>Cleaning inside cabinets & drawers</span>
              </li>
              <li class="flex items-center space-x-3">
                <span class="text-emerald-500 font-bold">✓</span>
                <span>Wiping down shelves & countertops</span>
              </li>
              <li class="flex items-center space-x-3">
                <span class="text-emerald-500 font-bold">✓</span>
                <span>Vacuuming & mopping all floors</span>
              </li>
              <li class="flex items-center space-x-3">
                <span class="text-emerald-500 font-bold">✓</span>
                <span>Sanitizing large appliances (exterior)</span>
              </li>
              <li class="flex items-center space-x-3">
                <span class="text-emerald-500 font-bold">✓</span>
                <span>Cleaning windows & glass surfaces</span>
              </li>
              <li class="flex items-center space-x-3">
                <span class="text-emerald-500 font-bold">✓</span>
                <span>Dusting baseboards, doors & trim</span>
              </li>
              <li class="flex items-center space-x-3">
                <span class="text-emerald-500 font-bold">✓</span>
                <span>Removing all remaining small debris</span>
              </li>
            </ul>
          </div>

          <!-- CTAs -->
          <div class="pt-6 flex flex-col sm:flex-row gap-4 border-t border-slate-100">
            <a 
              href={`https://wa.me/${siteInfo.phone.raw}?text=I'm%20interested%20in%20your%20move%20in/move%20out%20cleaning%20services.`} 
              target="_blank" 
              rel="noopener noreferrer" 
              class="inline-flex items-center justify-center px-6 py-3.5 border border-transparent text-base font-semibold rounded-xl text-white bg-green-600 hover:bg-green-700 shadow transition duration-200"
            >
              Book via WhatsApp
            </a>
            <a 
              href="/#services" 
              class="inline-flex items-center justify-center px-6 py-3.5 border border-slate-200 text-base font-semibold rounded-xl text-slate-600 hover:bg-slate-50 transition duration-200"
            >
              Back to Services
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>
</Layout>
