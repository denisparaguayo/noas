---
// src/pages/hcleaning.astro
import Layout from '../layouts/Layout.astro';
import { siteInfo } from '../data/siteInfo';
---

<Layout 
  title={`Professional House Cleaning Services | ${siteInfo.legalName}`} 
  description={`Get reliable and deep house cleaning services in the ${siteInfo.serviceArea.display}. We offer dusting, vacuuming, mopping, sanitizing, and eco-friendly options. Schedule your clean today!`}
>
  <!-- Header Page Title -->
  <section class="bg-slate-900 text-white py-16 sm:py-24 relative overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/1.jpg" alt="House Cleaning Banner" class="w-full h-full object-cover opacity-25" />
      <div class="absolute inset-0 bg-slate-950/80"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight">House Cleaning</h1>
      <p class="mt-4 text-lg text-slate-300 max-w-2xl mx-auto">
        Keep your home spotless, healthy, and comfortable with our custom cleaning schedules.
      </p>
    </div>
  </section>

  <!-- Service Detail Content -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        
        <!-- Main Image -->
        <div>
          <img src="/images/1.jpg" alt="House Cleaning Details" class="rounded-2xl shadow-xl w-full h-[400px] object-cover" />
          <div class="mt-6 bg-blue-50 p-6 rounded-2xl border border-blue-100/50">
            <h3 class="text-lg font-bold text-blue-900 mb-2">🌿 Eco-Friendly Cleaning Option</h3>
            <p class="text-sm text-blue-800 leading-relaxed">
              We care about your family and pets. Upon request, we offer natural, non-toxic cleaning product options for clients with sensitivities or allergies to strong chemicals.
            </p>
          </div>
        </div>

        <!-- Details -->
        <div class="space-y-8">
          <div>
            <h2 class="text-3xl font-extrabold text-slate-900 mb-4">A Pristine Home, Stress-Free</h2>
            <p class="text-slate-600 leading-relaxed">
              Our residential cleaning service is designed to give you back your free time while maintaining an immaculate home. Whether you need a regular weekly, bi-weekly, or monthly schedule, or a deep one-time clean, our professional cleaners ensure every corner is spotless.
            </p>
          </div>

          <div>
            <h3 class="text-xl font-bold text-slate-900 mb-4">Our House Cleaning Includes:</h3>
            <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-slate-600">
              <li class="flex items-center space-x-3">
                <span class="text-emerald-500 font-bold">✓</span>
                <span>Dusting all surfaces</span>
              </li>
              <li class="flex items-center space-x-3">
                <span class="text-emerald-500 font-bold">✓</span>
                <span>Vacuuming carpets & rugs</span>
              </li>
              <li class="flex items-center space-x-3">
                <span class="text-emerald-500 font-bold">✓</span>
                <span>Mopping hard floors</span>
              </li>
              <li class="flex items-center space-x-3">
                <span class="text-emerald-500 font-bold">✓</span>
                <span>Sanitizing bathrooms & toilets</span>
              </li>
              <li class="flex items-center space-x-3">
                <span class="text-emerald-500 font-bold">✓</span>
                <span>Deep kitchen cleaning</span>
              </li>
              <li class="flex items-center space-x-3">
                <span class="text-emerald-500 font-bold">✓</span>
                <span>Cleaning windows & mirrors</span>
              </li>
              <li class="flex items-center space-x-3">
                <span class="text-emerald-500 font-bold">✓</span>
                <span>Taking out trash & recycling</span>
              </li>
              <li class="flex items-center space-x-3">
                <span class="text-emerald-500 font-bold">✓</span>
                <span>Wiping baseboards & switches</span>
              </li>
            </ul>
          </div>

          <!-- CTAs -->
          <div class="pt-6 flex flex-col sm:flex-row gap-4 border-t border-slate-100">
            <a 
              href={`https://wa.me/${siteInfo.phone.raw}?text=I'm%20interested%20in%20your%20house%20cleaning%20services.`} 
              target="_blank" 
              rel="noopener noreferrer" 
              class="inline-flex items-center justify-center px-6 py-3.5 border border-transparent text-base font-semibold rounded-xl text-white bg-green-600 hover:bg-green-700 shadow transition duration-200"
            >
              Book via WhatsApp
            </a>
            <a 
              href="/#services" 
              class="inline-flex items-center justify-center px-6 py-3.5 border border-slate-200 text-base font-semibold rounded-xl text-slate-600 hover:bg-slate-50 transition duration-200"
            >
              Back to Services
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>
</Layout>
